@import colors

.post-view
    width: 100%
    display: flex !important
    flex-direction: row

    >.sidebar
        margin-right: 1em
        min-width: 21em
        max-width: 21em
        line-height: 160%

        a:active
            border: 0
            outline: 0

    >.sidebar>nav.buttons, >.content nav.buttons
        margin-top: 0
        display: flex
        flex-wrap: wrap
        article
            flex: 1 0 33%
            a
                display: inline-block
                width: 100%
                padding: 0.3em 0
                text-align: center
                vertical-align: middle
                transition: background 0.2s linear, box-shadow 0.2s linear
                &:not(.inactive):hover
                    background: lighten($main-color, 90%)
            i
                font-size: 140%
            text-align: center
        @media (max-width: 800px)
            margin-top: 0.6em
            margin-bottom: 0.6em

    >.content
        width: 100%

    .post-container
        margin-bottom: 0.6em
        overflow-x: auto

        .post-content
            margin: 0
            background-size: cover
            background-repeat: no-repeat

    .description-container
        background: $top-navigation-color
        padding: 0.6em

    #post-description
        resize: vertical
        min-height: 200px

    .after-mobile-controls
        width: 100%

.darktheme .post-view
    >.sidebar, >.content
        nav.buttons
            article
                a:not(.inactive):hover
                    background: unset
                    box-shadow: inset 0 0 0 0.3em $main-color

    .description-container
        background: $top-navigation-color-darktheme

@media (max-width: 800px)
    .post-view
        flex-wrap: wrap
        >.after-mobile-controls
            order: 3
        >.sidebar
            order: 2
            min-width: 100%
            max-width: 0
            margin-right: 0
        >.content
            order: 1


.post-view .readonly-sidebar
    .details
        i
            margin-right: 0.6em
            display: inline-block
            width: 1em
            text-align: center

        .safety-safe
            color: $safety-safe
        .safety-sketchy
            color: $safety-sketchy
        .safety-unsafe
            color: $safety-unsafe

        .upload-info
            .thumbnail
                width: 1em
                height: 1em
                margin: -0.1em 0.6em 0 0

        .zoom
            margin-top: 1em
            a
                display: inline-block
            .active
                text-decoration: underline

        .social
            margin-top: 1em
            .score-container
                float: left
                margin-right: 3em
                .downvote i
                    text-align: right
            i
                text-align: left
                margin: 0
            .value
                text-align: center
                display: inline-block
                width: 2em

    .relations
        margin-top: 2em
        h1
            margin-bottom: 0.5em
        .thumbnail
            width: 4em
            height: 3em
            background-position: 50% 30%
        li
            margin: 0 0.3em 0.3em 0
            display: inline-block

    .tags
        margin-top: 2em
        h1
            margin-bottom: 0.5em

.post-view .edit-sidebar
    .expander-content
        section:not(:last-child)
            margin-bottom: 1em

    .safety
        &>label
            width: 100%
        .radio-wrapper
            display: flex
            flex-wrap: wrap
        .radio-wrapper label
            flex-grow: 1
            display: inline-block

    .management
        ul
            list-style-type: none
            margin: 0
            padding: 0
            li
                margin: 0
                padding: 0

    .post-source
        textarea
            white-space: pre
            overflow-wrap: normal
            overflow-x: scroll

    form
        width: auto

    label:not(.file-dropper)
        margin-bottom: 0.3em
        display: block

    input[type=submit],
    input[type=button],
    button
        width: 100%
        &:focus
            border: 2px solid $text-color !important

    .messages
        margin-top: 1em

/* 10booru post sidebar layout */
.post-view .readonly-sidebar
    .details
        margin-bottom: 0.9em

        .social
            display: grid
            grid-template-columns: repeat(3, 1fr)
            align-items: center
            margin: 0 0 0.65em
            padding: 0.15em 0 0.55em
            border-bottom: 1px solid rgba(0, 0, 0, 0.12)

            .score-container
                grid-column: 1 / 3
                display: flex
                align-items: center
                justify-content: space-around
                float: none
                margin-right: 0
                white-space: nowrap

            .fav-container
                grid-column: 3
                display: flex
                align-items: center
                justify-content: center
                white-space: nowrap

            i
                margin: 0
                text-align: center

            .value
                width: auto
                min-width: 1.5em
                text-align: center

        .statistics-header
            margin: 0 0 0.4em
            font-size: 1em
            font-weight: bold
            line-height: 1.2

        .statistics-body
            margin: 0 0 0.8em
            padding: 0 0 0.75em
            border-bottom: 1px solid rgba(0, 0, 0, 0.12)

            section
                margin: 0
                line-height: 1.35

            section + section
                margin-top: 0.12em

            .post-id
                margin: 0.08em 0 0.32em

            .safety
                margin-bottom: 0.12em

            .zoom
                margin-top: 0.28em

            .source
                display: block
                margin-top: 0.16em
                line-height: 1.3

                .source-label
                    display: inline
                    line-height: 1.25

                    &::after
                        content: " "

                .source-links
                    display: inline
                    width: auto
                    max-width: none
                    line-height: inherit

                a
                    display: inline
                    max-width: none
                    white-space: normal
                    word-break: break-all
                    overflow-wrap: normal

            .search
                margin-top: 0.22em

    .relations
        margin-top: 1.2em

    .tags
        margin-top: 0

        .tag-category-header
            margin: 0.9em 0 0.35em
            font-size: 1em
            font-weight: bold
            line-height: 1.2

            &:first-of-type
                margin-top: 0

        .compact-tags
            margin: 0 0 0.25em

// 10booru post edit file dropper UX
.post-view .edit-sidebar
    .dropper-container
        text-align: center

    .file-dropper
        display: block
        box-sizing: border-box
        width: 100%
        padding: 0.9em 0.6em
        border: 2px solid $main-color
        background: $top-navigation-color
        color: $text-color
        cursor: pointer

        &:hover,
        &.active
            border-color: $main-color

        small
            display: block
            margin-top: 0.45em
            color: $inactive-link-color
            font-size: 85%
            line-height: 1.3

    .url-toggle
        display: inline-block
        width: auto
        margin: 0.6em 0 0 0
        padding: 0
        border: 0
        background: transparent
        color: $main-color
        font: inherit
        cursor: pointer

        &:hover
            text-decoration: underline

        &:focus
            border: 0 !important
            outline: 1px dotted $main-color

    .url-holder
        margin-top: 0.6em

        &[hidden]
            display: none

.darktheme .post-view .edit-sidebar
    .file-dropper
        background: $top-navigation-color-darktheme
        color: $text-color-darktheme

        small
            color: $inactive-link-color-darktheme

// 10booru post relation strip
.post-view
    .post-relation-strip
        margin: 0 0 0.7em 0
        padding: 0.55em 0.7em
        border: 1px solid $line-color
        background: $top-navigation-color
        box-sizing: border-box

    .post-relation-strip-header
        margin-bottom: 0.55em
        font-size: 90%

        a
            margin-left: 0.35em

    .post-relation-strip.collapsed
        padding-top: 0.35em
        padding-bottom: 0.35em

        .post-relation-strip-header
            margin-bottom: 0
            line-height: 1.15

    .post-relation-strip-posts
        display: flex
        flex-wrap: wrap
        gap: 0.55em
        align-items: flex-start

    .post-relation-strip-posts[hidden]
        display: none

    .post-relation-strip-thumbnail
        display: block
        padding: 0
        border: 2px solid $main-color
        background: transparent
        line-height: 0

        &.current
            box-shadow: 0 0 0 0.25em $line-color

        .thumbnail
            display: block
            width: auto
            height: auto
            line-height: 0
            background-image: none !important

            img
                display: block
                width: auto
                height: 9em
                max-width: 14em
                opacity: 1
                position: static

    .readonly-sidebar
        nav.relations
            display: none

.darktheme .post-view
    .post-relation-strip
        background: $top-navigation-color-darktheme

    .post-relation-strip-thumbnail
        background: transparent

        &.current
            box-shadow: 0 0 0 0.25em $top-navigation-color-darktheme

.post-view .readonly-sidebar
    .post-history-link
        margin-top: 0.8em
        padding-top: 0.65em
        border-top: 1px solid $line-color

.post-history-page
    max-width: 56em
    margin: 0 auto
    padding: 1em

    h1
        margin: 0 0 0.55em

    .post-history-post
        margin: 0 0 0.75em
        color: $inactive-link-color
        line-height: 1.35

    .post-history-error,
    .revision-error
        margin: 0 0 0.75em
        padding: 0.5em
        border-left: 0.25em solid $main-color

    .revision-list
        margin: 0
        padding: 0
        list-style: none

    .revision
        padding: 0.8em 0
        border-top: 1px solid $line-color

        &:first-child
            border-top: 0

    .revision-header
        display: flex
        justify-content: space-between
        gap: 0.5em

    .revision-time
        flex: 0 0 auto
        font-size: 85%
        white-space: nowrap

    .revision-meta,
    .revision-summary
        margin: 0.3em 0 0
        color: $inactive-link-color
        line-height: 1.35

    .revision-editor
        a
            white-space: nowrap

        img
            width: 1.35em
            height: 1.35em
            margin: 0 0.25em
            vertical-align: middle

    .restore-revision,
    .load-more-revisions
        width: auto
        margin-top: 0.6em

    .revision-details
        margin-top: 0.6em

        dl
            margin: 0.5em 0 0

        dl > div
            margin-top: 0.45em

        dt
            font-weight: bold

        dd
            margin: 0.1em 0 0

        pre
            margin: 0
            white-space: pre-wrap
            overflow-wrap: anywhere
            font: inherit

.darktheme .post-view .readonly-sidebar .post-history-link
    border-color: $line-color

.darktheme .post-history-page
    .post-history-post,
    .revision-meta,
    .revision-summary
        color: $inactive-link-color-darktheme

@media (max-width: 800px)
    .post-history-page
        .revision-header
            display: block

        .revision-time
            display: block
            margin-top: 0.15em
